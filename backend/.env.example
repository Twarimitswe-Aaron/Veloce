# Veloce Local Coordinator configuration.
# Copy this file to `.env` and adjust as needed. Real environment variables
# always override values set here.

# Port for the WebSocket + dev server.
VELOCE_PORT=14921

# How many downloads may run concurrently (engine processes).
VELOCE_MAX_CONCURRENT_DOWNLOADS=3

# Default number of parallel connections per download.
VELOCE_DEFAULT_THREADS=8

# Global speed cap per download, in BYTES per second. 0 = unlimited.
# Example: 5 MB/s => 5242880
VELOCE_MAX_RATE_BYTES=0

# Refuse to start a download if less than this many MB are free on the volume.
VELOCE_MIN_FREE_DISK_MB=500

# Optional: override the default base download directory.
# Leave empty to use ~/Downloads/Veloce.
VELOCE_BASE_DIR=

# Lock the WebSocket to specific extension IDs (comma-separated). When empty,
# any chrome-/moz-extension origin is allowed but ordinary websites are blocked.
# Example: VELOCE_ALLOWED_EXTENSION_IDS=abcdefghijklmnopabcdefghijklmnop
VELOCE_ALLOWED_EXTENSION_IDS=

# Block downloads pointing at localhost/loopback/private/link-local hosts
# (defends against SSRF and cloud metadata endpoints). true / false.
VELOCE_BLOCK_PRIVATE_HOSTS=true
